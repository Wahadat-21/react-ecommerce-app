import { useParams } from "react-router-dom";
import products from "../data/products";

function Product() {
  const { id } = useParams();

  const product = products.find(
    p => p.id === Number(id)
  );

  return (
    <div>
      <h1>{product.name}</h1>

      <img
        src={product.image}
        alt={product.name}
      />

      <h2>${product.price}</h2>

      <button>Add To Cart</button>
    </div>
  );
}

export default Product;
